# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VERTEX AI Configuration
# Required for switching to the Vertex AI backend infrastructure.
VERTEX_PROJECT_ID="your-google-cloud-project-id"
VERTEX_LOCATION="us-central1"

# To support the transition, because Vertex AI does not support API Keys, 
# you MUST provide a full Service Account JSON payload if your host container 
# doesn't inherently have Cloud Run bindings to your Vertex project.
# Paste the entire JSON string inside the quotes here (on one line if possible):
# GOOGLE_CREDENTIALS_JSON="{ \"type\": \"service_account\", \"project_id\": \"...\" }"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
