# Local Vertex AI proxy configuration.
# The React app runs on :3000 and proxies `/api/*` to the local Node server on :3001.

GOOGLE_CLOUD_PROJECT="YOUR_GCP_PROJECT_ID"
GOOGLE_CLOUD_LOCATION="global"
GOOGLE_GENAI_API_VERSION="v1"

# Optional: paste the full service account JSON on one line, set this to a JSON file path,
# or leave it unset and use Application Default Credentials from your shell.
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"YOUR_GCP_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}'
 
# Optional frontend override. Leave as `/api` for local development.
VITE_API_BASE_URL="/api"
VITE_APP_URL="http://localhost:3000/"
